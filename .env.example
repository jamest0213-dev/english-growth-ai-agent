# App
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
# development 預設使用 SQLite（可留空）；production 請填 PostgreSQL 連線
DATABASE_URL=
POSTGRES_DB=english_growth
POSTGRES_USER=english_user
POSTGRES_PASSWORD=english_password
POSTGRES_PORT=5432

# LLM provider
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
